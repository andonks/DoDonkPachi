  } else if (type === 'moth--prototype') { // don't you wanna be a MOTH MOTH MOTH
    ctx.scale(4,4);

    // front parts
    ctx.fillStyle = 'white';
    ctx.beginPath();
    ctx.ellipse(2, 5, 1.5, 2.5, 0, 0, Math.PI * 2); ctx.closePath(); ctx.fill();
    ctx.beginPath();
    ctx.ellipse(-2, 5, 1.5, 2.5, 0, 0, Math.PI * 2); ctx.closePath(); ctx.fill();

    // small Wings
    ctx.fillStyle = neonPink;
    ctx.beginPath();
