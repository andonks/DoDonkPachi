    ctx.lineTo(3.5, -4);
    ctx.lineTo(8, -8);
    ctx.lineTo(8, 0);
    ctx.lineTo(0, 5);
    ctx.lineTo(0, -2);
    ctx.closePath(); ctx.fill();
    ctx.beginPath();
    ctx.moveTo(-2, -1);
    ctx.lineTo(-3.5, -2);
    ctx.lineTo(-3.5, -4);
    ctx.lineTo(-8, -8);
    ctx.lineTo(-8, 0);
    ctx.lineTo(0, 5);
    ctx.lineTo(0, -2);
    ctx.closePath(); ctx.fill();

    ctx.strokeStyle = neonPurp;
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(0, 5);
    ctx.lineTo(-8, 0);
    ctx.lineTo(-8, -5);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(0, 5);
    ctx.lineTo(8, 0);
    ctx.lineTo(8, -5);
    ctx.stroke();

    //body & cockpit
