    ctx.lineTo(-1, 3);
    ctx.lineTo(1, 3);
    ctx.lineTo(2, 2);
    ctx.lineTo(2, -2);
    ctx.lineTo(2, -2);
    ctx.lineTo(1, -3);
    ctx.closePath(); ctx.fill();
    ctx.stroke();

    ctx.strokeStyle = neonPurp;
    ctx.beginPath();
    ctx.moveTo(-2, -2);
    ctx.lineTo(0, 0);
    ctx.lineTo(2, -2);
