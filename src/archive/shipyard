  ctx.closePath(); ctx.fill();
  ctx.fillStyle = 'hotpink';
  ctx.beginPath();
  ctx.arc(0, 0, 28, 0, Math.PI * 2); ctx.closePath(); ctx.fill();
  ctx.fillStyle = 'brown';
  ctx.beginPath();
  ctx.arc(0, 0, 18, 0, Math.PI * 2); ctx.closePath(); ctx.fill();

} else if (type === 'turret') { // TURRET
